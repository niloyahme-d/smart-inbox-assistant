# Copy this file to .env and fill in your values.
# Only one provider's key is required — set LLM_PROVIDER to pick which one.

# "openai" or "gemini"
LLM_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Optional path overrides ---
# SIA_DATA_PATH=data/sample_emails.json
# SIA_OUTPUT_JSON=outputs/processed_emails.json
# SIA_OUTPUT_CSV=outputs/processed_emails.csv
