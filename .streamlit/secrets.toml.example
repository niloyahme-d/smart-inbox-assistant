# Streamlit Community Cloud: paste these into
# App settings -> Secrets, then Streamlit exposes them as env vars automatically
# when you access them via st.secrets, OR set them as real environment
# variables in the same panel. This project reads plain env vars via
# os.getenv(), so add them under the "Secrets" text box in TOML form:

LLM_PROVIDER = "openai"
OPENAI_API_KEY = "sk-..."
OPENAI_MODEL = "gpt-4o-mini"

GEMINI_API_KEY = ""
GEMINI_MODEL = "gemini-1.5-flash"
